# Ключи LLM — обязательны для скоринга, писем и поиска HR-почты.
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...

# App-пароль Gmail (SMTP/IMAP) — нужен только для email-канала: реальной отправки
# писем HR (approve_email) и выгрузки черновиков в Gmail (draft_to_gmail).
# Без него MCP-сервер поднимается, недоступен только email-канал.
SMTP_PASSWORD=
